# 本地开发：无 Docker 时用 SQLite
DATABASE_URL=sqlite:///./backend/homework.db

# 云端 PostgreSQL：
# DATABASE_URL=postgresql://homework:homework@localhost:5432/homework

# false=必须登录；true=免登录开发（仅本地）
DEV_MODE=false

# JWT（生产环境务必修改）
JWT_SECRET=请改为随机长字符串

# 初始管理员（首次启动自动创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# CORS_ORIGINS=https://your-domain.com
